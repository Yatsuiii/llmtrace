<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>llmtrace · the tape</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0c0a07; --panel: #14110b; --inset: #0a0805;
    --line: rgba(255,198,128,0.08); --line-lit: rgba(255,198,128,0.17);
    --text: #e2d6bf; --muted: #8c7f66; --dim: #574d3c;
    --amber: #ffb000; --amber-hi: #ffce5c; --amber-dim: #b8862f;
    --green: #74a86e; --green-dim: #5f9457;
    --red: #d9534a; --red-dim: #8f3a34; --blue: #b8862f;
    --mono: 'JetBrains Mono', 'Cascadia Code', ui-monospace, monospace;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--mono);
    font-size: 13px; line-height: 1.5; -webkit-font-smoothing: antialiased;
    padding-bottom: 34px; font-variant-numeric: tabular-nums; }
  ::selection { background: rgba(255,176,0,0.28); color: #f0e7d3; }
  a { color: var(--amber); }

  /* ticker */
  .ticker { display: flex; align-items: center; height: 38px; border-bottom: 1px solid var(--line);
    background: #0a0805; padding: 0 16px; font-size: 12.5px; overflow: hidden; white-space: nowrap;
    position: sticky; top: 0; z-index: 5; }
  .ticker .brand { font-weight: 800; letter-spacing: -0.02em; color: #f0e7d3; }
  .ticker .brand b { color: var(--amber); }
  .ticker .cursor { color: var(--amber); animation: blink 1.1s steps(1) infinite; margin: 0 14px 0 4px; font-weight: 700; }
  @keyframes blink { 0%,50% { opacity:1; } 51%,100% { opacity:0; } }
  .ticker .seg { display: inline-flex; align-items: center; gap: 7px; padding: 0 16px;
    border-left: 1px solid var(--line); height: 100%; }
  .ticker .k { color: var(--dim); font-size: 11px; font-weight: 600; letter-spacing: 0.04em; }
  .ticker .v { color: var(--text); font-weight: 700; }
  .ticker .v.amber { color: var(--amber-hi); } .ticker .v.red { color: var(--red); } .ticker .v.green { color: var(--green); }
  .ticker .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green);
    box-shadow: 0 0 7px var(--green); animation: pulse 1.8s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
  .ticker .spacer { margin-left: auto; }

  .wrap { max-width: 1180px; margin: 0 auto; padding: 22px 16px 40px; }
  .panel { background: var(--panel); border: 1px solid var(--line); border-radius: 4px; margin-bottom: 14px; }
  .phd { display: flex; align-items: center; gap: 10px; padding: 11px 16px; border-bottom: 1px solid var(--line); }
  .phd .lbl { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .phd .lbl b { color: var(--amber); }
  .phd .meta { margin-left: auto; font-size: 11px; color: var(--dim); }
  .phd .meta .q { color: var(--muted); }
  .vision-tag { margin-left: auto; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    background: rgba(255,176,0,0.12); color: var(--amber-dim); border: 1px solid rgba(255,176,0,0.3);
    padding: 3px 8px; border-radius: 3px; }

  /* chart */
  .chart-wrap { padding: 16px; }
  .chart-wrap canvas { max-height: 280px; }

  /* watchlist */
  table.watch { width: 100%; border-collapse: collapse; }
  .watch th { text-align: left; font-size: 10.5px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--dim); padding: 9px 16px; border-bottom: 1px solid var(--line); }
  .watch th.r, .watch td.r { text-align: right; }
  .watch td { padding: 11px 16px; border-bottom: 1px solid var(--line); }
  .watch tr:last-child td { border-bottom: none; }
  .watch tr.hot td { background: rgba(217,83,74,0.045); }
  .watch tr:hover td { background: rgba(255,210,150,0.02); }
  .watch .key { font-weight: 700; color: var(--text); }
  .watch tr.hot .key { color: #e0938b; }
  .watch .perday { font-weight: 700; } .watch tr.hot .perday { color: var(--red); }
  .delta.up { color: var(--red); font-weight: 700; } .delta.flat { color: var(--green-dim); }
  .sig { color: var(--muted); font-weight: 600; } .sig.hot { color: var(--red); font-weight: 700; }
  .st { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; }
  .st .d { width: 6px; height: 6px; border-radius: 50%; }
  .st.crit { color: var(--red); } .st.crit .d { background: var(--red); box-shadow: 0 0 6px var(--red); }
  .st.ok { color: var(--green-dim); } .st.ok .d { background: var(--green-dim); }
  .mix { display: inline-flex; width: 84px; height: 6px; border-radius: 1px; overflow: hidden;
    border: 1px solid var(--line); vertical-align: middle; }
  .mix i { display: block; height: 100%; } .mix .s { background: var(--amber); } .mix .h { background: var(--dim); }
  .mixc { font-size: 10.5px; color: var(--dim); margin-left: 8px; }
  .spark { display: block; }

  /* watcher + live feed */
  .wbar { display: flex; align-items: center; gap: 14px; padding: 13px 16px; flex-wrap: wrap; }
  .wbar .pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--green);
    box-shadow: 0 0 8px var(--green); animation: pulse 1.8s ease-in-out infinite; }
  .wbar .wlabel { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--green); }
  .wbar .wmeta { font-size: 11px; color: var(--green-dim); }

  /* unified terminal button */
  .tbtn { font-family: var(--mono); font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
    color: var(--amber); background: transparent; border: 1px solid rgba(255,176,0,0.4);
    border-radius: 3px; padding: 7px 13px; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
  .tbtn:hover { background: rgba(255,176,0,0.12); border-color: var(--amber); }
  .tbtn:disabled { opacity: 0.45; cursor: default; }
  .wbar .tbtn { margin-left: auto; color: var(--green); border-color: rgba(111,159,106,0.35); }
  .wbar .tbtn:hover { background: rgba(111,159,106,0.12); border-color: var(--green); }

  .stream-box, .chat-output, .live-feed { display: none; background: var(--inset); border: 1px solid var(--line);
    border-radius: 3px; padding: 13px 15px; font-size: 12px; line-height: 1.7; overflow-y: auto;
    white-space: pre-wrap; max-height: 340px; color: var(--muted); }
  .stream-box.visible, .chat-output.visible, .live-feed.visible { display: block; }
  .stream-box { margin: 0 16px 16px; } .live-feed { margin: 0 16px 16px; color: #6f9f6a; }
  .live-feed .dim { color: var(--dim); } .live-feed .tool { color: var(--amber-dim); }
  .live-feed .attr { color: var(--text); } .live-feed .action { color: var(--amber); }

  /* projection */
  .proj { display: flex; align-items: baseline; gap: 20px; flex-wrap: wrap; padding: 14px 16px;
    border-color: rgba(255,176,0,0.26); }
  .proj .plbl { font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #c79a3f; }
  .proj .big { font-size: 26px; font-weight: 800; color: var(--amber); letter-spacing: -0.02em; }
  .proj .sub { font-size: 12px; color: #b89a63; } .proj .sub b { color: var(--red); }

  /* anomalies */
  .anom { padding: 16px; border-bottom: 1px solid var(--line); }
  .anom:last-child { border-bottom: none; }
  .anom-top { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .anom-key { font-weight: 700; color: #f0e7d3; } .anom-date { margin-left: auto; color: var(--dim); }
  .anom-metrics { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 14px; }
  .m { display: flex; flex-direction: column; gap: 3px; }
  .m .ml { font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--dim); }
  .m .mv { font-weight: 700; font-size: 14px; color: var(--text); } .m .mv.hot { color: var(--red); }
  .empty { padding: 18px 16px; color: var(--dim); }

  /* chat */
  .chat-box { padding: 16px; }
  .chat-row { display: flex; align-items: center; gap: 9px; }
  .chat-row .prompt { color: var(--amber); font-weight: 700; }
  .chat-row input { flex: 1; background: var(--inset); border: 1px solid var(--line); border-radius: 3px;
    padding: 10px 13px; color: var(--text); font-size: 13px; font-family: var(--mono); }
  .chat-row input:focus { outline: none; border-color: var(--amber); box-shadow: 0 0 0 3px rgba(255,176,0,0.1); }
  .chat-row input::placeholder { color: var(--dim); }
  .chips { margin-top: 11px; display: flex; gap: 8px; flex-wrap: wrap; }
  .chips button { background: rgba(255,210,150,0.04); color: var(--muted); border: 1px solid var(--line);
    border-radius: 3px; padding: 6px 11px; font-size: 11px; font-family: var(--mono); cursor: pointer; transition: all 0.15s; }
  .chips button:hover { background: rgba(255,176,0,0.1); color: var(--text); border-color: rgba(255,176,0,0.35); }
  .chat-box .chat-output { margin-top: 14px; }

  /* vision */
  .vbody { padding: 16px; }
  .vision-drop { border: 1.5px dashed var(--line-lit); border-radius: 4px; padding: 26px; text-align: center;
    cursor: pointer; transition: border-color 0.15s, background 0.15s; }
  .vision-drop:hover { border-color: var(--amber); background: rgba(255,176,0,0.04); }
  .vision-drop.has-file { border-color: var(--green); background: rgba(111,159,106,0.05); }
  .vision-drop .hint { color: var(--muted); font-size: 12.5px; line-height: 1.55; } .vision-drop .hint b { color: var(--text); }
  .vision-drop .fname { color: #9fc79a; font-weight: 700; }
  .vbody .chat-output { margin-top: 14px; }

  /* actions table */
  .actions-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .actions-table th { text-align: left; color: var(--dim); font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; padding: 11px 16px; border-bottom: 1px solid var(--line); }
  .actions-table td { padding: 11px 16px; border-bottom: 1px solid var(--line); vertical-align: top; }
  .actions-table tr:last-child td { border-bottom: none; }
  .actions-table tr:hover td { background: rgba(255,210,150,0.02); }
  .actions-table code { color: var(--amber-dim); } .actions-table .dimcell { color: var(--dim); white-space: nowrap; }
  .action-result a { color: var(--amber); text-decoration: none; font-weight: 700; }
  .action-result a:hover { text-decoration: underline; }
  .badge { font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.05em;
    background: rgba(255,210,150,0.06); color: var(--muted); border: 1px solid var(--line); }
  .badge.done { background: rgba(111,159,106,0.12); color: #9fc79a; border-color: rgba(111,159,106,0.3); }
  .badge.failed { background: rgba(217,83,74,0.12); color: #e0938b; border-color: rgba(217,83,74,0.3); }
  .badge.skipped { background: rgba(255,210,150,0.05); color: var(--muted); border-color: var(--line); }

  /* status bar */
  .statusbar { position: fixed; bottom: 0; left: 0; right: 0; height: 28px; display: flex; align-items: center;
    background: #0a0805; border-top: 1px solid var(--line); font-size: 11px; color: var(--dim);
    padding: 0 14px; z-index: 5; white-space: nowrap; overflow: hidden; }
  .statusbar .s { padding: 0 12px; border-right: 1px solid var(--line); height: 100%; display: inline-flex; align-items: center; gap: 6px; }
  .statusbar .s:first-child { padding-left: 0; } .statusbar .ready { color: var(--green); font-weight: 700; }
  .statusbar .s b { color: var(--muted); font-weight: 600; }
  .statusbar .right { margin-left: auto; border: none; }

  @media (max-width: 720px) {
    .ticker { font-size: 11px; } .ticker .seg { padding: 0 10px; }
    .anom-metrics { gap: 18px; }
  }
</style>
</head>
<body>

<div class="ticker">
  <span class="brand">llm<b>trace</b></span><span class="cursor">▌</span>
  <span class="seg"><span class="k">30D SPEND</span><span class="v amber">${{printf "%.2f" .TotalSpend}}</span></span>
  <span class="seg"><span class="k">ANOM</span><span class="v red">{{len .Anomalies}}</span></span>
  <span class="seg"><span class="k">ACTIONS</span><span class="v">{{len .AgentActions}}</span></span>
  {{if .Watcher.Active}}
  <span class="seg"><span class="dot"></span><span class="v green">AGENT ACTIVE</span><span class="k">scan {{.Watcher.ScanCount}}</span></span>
  <span class="seg spacer"><span class="k">NEXT</span><span class="v">{{.Watcher.NextScan}}</span></span>
  {{else}}
  <span class="seg spacer"><span class="k">{{.Now}}</span></span>
  {{end}}
</div>

<div class="wrap">

  <div class="panel">
    <div class="phd"><span class="lbl">DAILY SPEND · <b>30D</b></span><span class="meta"><span class="q">which deploy spiked the bill?</span></span></div>
    <div class="chart-wrap"><canvas id="costChart"></canvas></div>
  </div>

  {{if .Keys}}
  <div class="panel">
    <div class="phd"><span class="lbl">TRACKED KEYS</span><span class="meta">{{len .Keys}} keys · anthropic</span></div>
    <table class="watch">
      <thead><tr>
        <th>KEY</th><th>30D TREND</th><th class="r">$/DAY</th><th class="r">Δ</th><th>MODEL MIX</th><th class="r">σ</th><th class="r">STATUS</th>
      </tr></thead>
      <tbody>
      {{range .Keys}}
        <tr class="{{if .Hot}}hot{{end}}">
          <td class="key">{{.Key}}</td>
          <td>{{.Spark}}</td>
          <td class="r perday">${{printf "%.2f" .PerDay}}</td>
          <td class="r delta {{if .Hot}}up{{else}}flat{{end}}">{{.DeltaLabel}}</td>
          <td><span class="mix"><i class="s" style="flex:{{.Sonnet}}"></i><i class="h" style="flex:{{.Haiku}}"></i></span><span class="mixc">{{.MixLabel}}</span></td>
          <td class="r sig {{if .Hot}}hot{{end}}">{{if .Hot}}{{printf "%.1f" .Sigma}}{{else}}·{{end}}</td>
          <td class="r"><span class="st {{if .Hot}}crit{{else}}ok{{end}}"><span class="d"></span>{{.Status}}</span></td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </div>
  {{end}}

  {{if .Watcher.Active}}
  <div class="panel">
    <div class="wbar">
      <span class="pulse"></span>
      <span class="wlabel">Autonomous Agent · Active</span>
      <span class="wmeta">scans {{.Watcher.ScanCount}} · last {{.Watcher.LastScan}} · next {{.Watcher.NextScan}}</span>
      <button class="tbtn" onclick="toggleLiveFeed(this)">LIVE FEED ▾</button>
    </div>
    <div class="live-feed" id="liveFeed"></div>
  </div>
  {{end}}

  {{if .Projection.Show}}
  <div class="panel proj">
    <span class="plbl">Projected · {{.Projection.Key}}</span>
    <span class="big">${{printf "%.0f" .Projection.MonthlyNow}}/mo</span>
    <span class="sub">baseline run-rate ${{printf "%.0f" .Projection.MonthlyBase}}/mo · this regression adds
      <b>+${{printf "%.0f" .Projection.Overspend}}/mo</b> if left unfixed</span>
  </div>
  {{end}}

  <div class="panel">
    <div class="phd"><span class="lbl">Spend Anomalies</span></div>
    {{if .Anomalies}}
    {{range .Anomalies}}
      <div class="anom">
        <div class="anom-top">
          <span class="st crit"><span class="d"></span>ANOMALY</span>
          <span class="anom-key">{{.APIKeyID}}</span>
          <span class="anom-date">{{.Date}}</span>
        </div>
        <div class="anom-metrics">
          <div class="m"><span class="ml">actual</span><span class="mv hot">${{printf "%.2f" .ActualValue}}</span></div>
          <div class="m"><span class="ml">baseline 7d</span><span class="mv">${{printf "%.2f" .BaselineValue}}</span></div>
          <div class="m"><span class="ml">delta</span><span class="mv hot">+${{printf "%.2f" .Delta}}</span></div>
          <div class="m"><span class="ml">sigma</span><span class="mv hot">{{printf "%.1f" .Sigma}}σ</span></div>
          <div class="m"><span class="ml">calls</span><span class="mv">{{.SampleSize}}</span></div>
        </div>
        <button class="tbtn" onclick="investigate({{.ID}}, this)">INVESTIGATE →</button>
        <div class="stream-box" id="stream-{{.ID}}" style="margin-top:14px"></div>
      </div>
    {{end}}
    {{else}}
    <div class="empty">No anomalies detected in the last 30 days.</div>
    {{end}}
  </div>

  <div class="panel">
    <div class="phd"><span class="lbl">Ask the Agent</span></div>
    <div class="chat-box">
      <div class="chat-row">
        <span class="prompt">&gt;</span>
        <input id="chatInput" type="text" autocomplete="off"
          placeholder="why did prod-frontend spike?"
          onkeydown="if(event.key==='Enter')sendChat()">
        <button class="tbtn" onclick="sendChat()">ASK</button>
      </div>
      <div class="chips">
        <button onclick="askThis('Why did prod-frontend spend spike?')">why did prod-frontend spike?</button>
        <button onclick="askThis('How much extra will this cost per month if unfixed?')">monthly cost impact?</button>
        <button onclick="askThis('Did the control keys change at all around the deploy?')">did the controls change?</button>
      </div>
      <div class="chat-output" id="chatOutput"></div>
    </div>
  </div>

  <div class="panel">
    <div class="phd"><span class="lbl">Investigate Any Dashboard</span><span class="vision-tag">Gemini Vision</span></div>
    <div class="vbody">
      <div class="vision-drop" id="visionDrop" onclick="document.getElementById('visionFile').click()">
        <div class="hint" id="visionHint">Drop a screenshot of <b>any</b> LLM billing dashboard: Anthropic, OpenAI, a Grafana panel.
          Gemini reads the spend off the image, then the agent finds which deploy caused the spike.</div>
      </div>
      <input type="file" id="visionFile" accept="image/*" style="display:none" onchange="visionPicked()">
      <button class="tbtn" style="margin-top:12px" onclick="runVision()">READ &amp; INVESTIGATE →</button>
      <div class="chat-output" id="visionOutput"></div>
    </div>
  </div>

  {{if .AgentActions}}
  <div class="panel">
    <div class="phd"><span class="lbl">Agent Actions Log</span></div>
    <table class="actions-table">
      <thead><tr><th>Time</th><th>Action</th><th>Anomaly</th><th>Status</th><th>Result</th></tr></thead>
      <tbody>
      {{range .AgentActions}}
        <tr>
          <td class="dimcell">{{.CreatedAt.Format "01-02 15:04"}}</td>
          <td><code>{{.ActionType}}</code></td>
          <td class="dimcell">#{{.AnomalyID}}</td>
          <td><span class="badge {{.Status}}">{{.Status}}</span></td>
          <td class="action-result" id="result-{{.ID}}">{{.Result}}</td>
        </tr>
      {{end}}
      </tbody>
    </table>
  </div>
  {{end}}

</div>

<div class="statusbar">
  <span class="s ready">● READY</span>
  {{if .Watcher.Active}}
  <span class="s">scan <b>#{{.Watcher.ScanCount}}</b></span>
  <span class="s">last <b>{{.Watcher.LastScan}}</b></span>
  <span class="s">next <b>{{.Watcher.NextScan}}</b></span>
  {{else}}
  <span class="s"><b>{{.Now}}</b></span>
  {{end}}
  <span class="s">proxy <b>:8080</b></span>
  <span class="s right">MIT · llmtrace v0.2</span>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.0.1/dist/chartjs-plugin-annotation.min.js"></script>
<script>
(function() {
  const d = {{.ChartDataJSON}};
  const ctx = document.getElementById('costChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: { labels: d.labels, datasets: d.datasets },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      interaction: { mode: 'index', intersect: false },
      scales: {
        x: { ticks: { color: '#8c7f66', maxTicksLimit: 10, font: { size: 11, family: 'JetBrains Mono' } },
             grid: { color: 'rgba(255,210,150,0.05)' } },
        y: { ticks: { color: '#8c7f66', font: { size: 11, family: 'JetBrains Mono' }, callback: v => '$' + v.toFixed(2) },
             grid: { color: 'rgba(255,210,150,0.05)' } }
      },
      plugins: {
        legend: { labels: { color: '#e2d6bf', font: { size: 12, family: 'JetBrains Mono' }, boxWidth: 12, usePointStyle: true } },
        tooltip: { backgroundColor: '#14110b', borderColor: 'rgba(255,210,150,0.12)', borderWidth: 1, padding: 11,
          titleColor: '#e2d6bf', bodyColor: '#8c7f66', titleFont: { family: 'JetBrains Mono' }, bodyFont: { family: 'JetBrains Mono' },
          callbacks: { label: ctx => ' ' + ctx.dataset.label + ': $' + ctx.parsed.y.toFixed(2) } },
        annotation: { annotations: d.annotations }
      }
    }
  });
})();

async function investigate(id, btn) {
  const box = document.getElementById('stream-' + id);
  box.textContent = '';
  box.classList.add('visible');
  btn.disabled = true;
  btn.textContent = 'INVESTIGATING…';
  const resp = await fetch('/investigate?id=' + id);
  const reader = resp.body.getReader();
  const dec = new TextDecoder();
  while (true) {
    const {done, value} = await reader.read();
    if (done) break;
    dec.decode(value).split('\n').forEach(line => {
      if (line.startsWith('data: ')) {
        box.textContent += line.slice(6) + '\n';
        box.scrollTop = box.scrollHeight;
      }
    });
  }
  btn.textContent = 'RE-INVESTIGATE';
  btn.disabled = false;
}

let liveEs = null;
function toggleLiveFeed(btn) {
  const feed = document.getElementById('liveFeed');
  if (liveEs) {
    liveEs.close(); liveEs = null;
    feed.classList.remove('visible');
    btn.textContent = 'LIVE FEED ▾';
    return;
  }
  feed.classList.add('visible');
  btn.textContent = 'LIVE FEED ▴';
  liveEs = new EventSource('/events');
  liveEs.onmessage = e => {
    const msg = e.data;
    const line = document.createElement('div');
    if (msg.startsWith('[tool]')) line.className = 'tool';
    else if (msg.startsWith('── Attribution')) line.className = 'attr';
    else if (msg.startsWith('[watcher]')) line.className = 'action';
    else if (msg.startsWith('[')) line.className = 'dim';
    line.textContent = msg;
    feed.appendChild(line);
    feed.scrollTop = feed.scrollHeight;
  };
}

function visionPicked() {
  const f = document.getElementById('visionFile').files[0];
  if (!f) return;
  document.getElementById('visionDrop').classList.add('has-file');
  document.getElementById('visionHint').innerHTML =
    '<span class="fname">' + f.name + '</span> · ready to investigate';
}

async function runVision() {
  const inp = document.getElementById('visionFile');
  if (!inp.files.length) { alert('Pick a screenshot first.'); return; }
  const out = document.getElementById('visionOutput');
  out.textContent = '';
  out.classList.add('visible');
  const fd = new FormData();
  fd.append('image', inp.files[0]);
  let resp;
  try {
    resp = await fetch('/vision', { method: 'POST', body: fd });
  } catch (e) {
    out.textContent = 'request failed: ' + e;
    return;
  }
  const reader = resp.body.getReader();
  const dec = new TextDecoder();
  while (true) {
    const {done, value} = await reader.read();
    if (done) break;
    dec.decode(value).split('\n').forEach(line => {
      if (line.startsWith('data: ')) {
        const msg = line.slice(6);
        if (msg === '[[END]]') return;
        out.textContent += msg + '\n';
        out.scrollTop = out.scrollHeight;
      }
    });
  }
}

function askThis(q) {
  document.getElementById('chatInput').value = q;
  sendChat();
}

let chatEs = null;
function sendChat() {
  const inp = document.getElementById('chatInput');
  const q = inp.value.trim();
  if (!q) return;
  const out = document.getElementById('chatOutput');
  out.textContent = '';
  out.classList.add('visible');
  if (chatEs) chatEs.close();
  chatEs = new EventSource('/chat?q=' + encodeURIComponent(q));
  chatEs.onmessage = e => {
    if (e.data === '[[END]]') { chatEs.close(); chatEs = null; return; }
    out.textContent += e.data + '\n';
    out.scrollTop = out.scrollHeight;
  };
  chatEs.onerror = () => { if (chatEs) { chatEs.close(); chatEs = null; } };
}

document.querySelectorAll('.action-result').forEach(td => {
  try {
    const obj = JSON.parse(td.textContent);
    if (obj.html_url) {
      td.innerHTML = '<a href="' + obj.html_url + '" target="_blank">#' + obj.number + ' ↗</a>';
    } else if (obj.note) {
      td.textContent = obj.note;
    } else if (obj.error) {
      td.style.color = '#e0938b';
      td.textContent = obj.error;
    } else if (obj.rpm) {
      td.textContent = obj.key + ' → ' + obj.rpm + ' rpm';
    }
  } catch(_) {}
});
</script>
</body>
