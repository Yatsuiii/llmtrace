# Powers the investigation agent (causal attribution, chat, vision).
# Free: grab a key at https://aistudio.google.com/apikey (free tier is plenty).
# Everything deterministic (proxy, ledger, detection, correlation) runs without it.
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# Alternative to GEMINI_API_KEY: use Vertex AI instead of Gemini API key auth.
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# GitHub access for the agent: read PR diffs and open remediation PRs.
# Token needs `repo` scope on the demo app repo.
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your-username/llmtrace-demo-app

# Optional: override the workflow name pattern used to detect deploys (default: deploy.*)
# DEPLOY_WORKFLOW_PATTERN=deploy.*

# Upstream provider key for the /v1/messages proxy. Only needed to route live
# traffic. Your own key, forwarded untouched. Real calls, real cost.
ANTHROPIC_API_KEY=your_anthropic_key_here
