GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# GitHub access for the agent: read PR diffs and open remediation PRs.
# Token needs `repo` scope on the demo app repo.
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=your-username/llmtrace-demo-app

# Upstream provider key for the /v1/messages proxy — real calls, real cost.
ANTHROPIC_API_KEY=your_anthropic_key_here
